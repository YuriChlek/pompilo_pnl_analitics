{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "..",
    "testMatch": ["<rootDir>/test/integration/**/*.spec.ts"],
    "testEnvironment": "node",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1"
    }
}
